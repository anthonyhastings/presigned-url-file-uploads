{
  "name": "presigned-url-file-uploads",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.0",
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "private": true,
  "scripts": {
    "build": "next build",
    "check:dependencies": "pnpm install --resolution-only --strict-peer-dependencies",
    "check:format": "prettier --check .",
    "check:types": "tsc --noEmit --project ./tsconfig.json",
    "dev": "next dev",
    "lint": "eslint",
    "lint:check-config": "eslint-config-prettier src/app/page.tsx",
    "lint:print-config": "eslint --print-config src/app/page.tsx",
    "start": "next start",
    "tf:apply": "terraform -chdir=terraform/ apply tfplan",
    "tf:init": "terraform -chdir=terraform/ init",
    "tf:plan": "terraform -chdir=terraform/ plan --out=tfplan",
    "tf:validate": "terraform -chdir=terraform/ validate"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.33.0",
    "@emotion/react": "^11.14.0",
    "@google-cloud/storage": "^7.12.1",
    "@hookform/resolvers": "^5.2.2",
    "nanoid": "^5.0.7",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.65.0",
    "react-icons": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.3.3",
    "typescript": "5.3.3"
  }
}
